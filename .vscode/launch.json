            "justMyCode": true,
            "env": {
                "PYDEVD_WARN_EVALUATION_TIMEOUT": "60",
                "PYDEVD_UNBLOCK_THREADS_TIMEOUT": "10",
                "PYDEVD_THREAD_DUMP_ON_WARN_EVALUATION_TIMEOUT": "true",
                "PYDEVD_INTERRUPT_THREAD_TIMEOUT": "15"
            }
        }
    ]
